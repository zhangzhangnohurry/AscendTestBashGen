# Command Workbench model configuration
# Recommended: configure in the web Settings panel. These env vars are optional defaults for the server.

# No model configured; raw text is not parsed or inferred.
WORKBENCH_LLM_PROVIDER=disabled

# Local Claude CLI: calls the local `claude -p` command on the server machine.
# WORKBENCH_LLM_PROVIDER=local-claude
# WORKBENCH_LLM_MODEL=sonnet

# Local Codex CLI: calls the local `codex exec` command on the server machine.
# WORKBENCH_LLM_PROVIDER=local-codex
# WORKBENCH_LLM_MODEL=gpt-5.5

# LLM API / HTTP model API: URL + key + model. If URL is a base URL, /v1/chat/completions is appended.
# WORKBENCH_LLM_PROVIDER=llm-api
# WORKBENCH_LLM_URL=https://api.openai.com
# WORKBENCH_LLM_API_KEY=...
# WORKBENCH_LLM_MODEL=gpt-4.1

# Optional timeout for local CLI/API calls. Default is 10 minutes.
WORKBENCH_LLM_TIMEOUT_MS=600000

# Advanced custom adapters are documented in docs/adapter-contract.md.
# custom-http is a Workbench JSON adapter endpoint, not a direct model API; it owns its model selection.
# WORKBENCH_LLM_PROVIDER=custom-cli
# WORKBENCH_LLM_COMMAND=/absolute/path/to/your-json-adapter
# WORKBENCH_LLM_PROVIDER=custom-http
# WORKBENCH_LLM_URL=http://127.0.0.1:8787/workbench-llm
# WORKBENCH_LLM_API_KEY_HEADER=Authorization
# WORKBENCH_LLM_API_KEY_PREFIX=Bearer
