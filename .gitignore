# Command Workbench — user/service delivery ignore template
# Use this when preparing the code bundle that is handed to end users.
# Goal: keep runnable service code, examples and normal product docs; drop local
# runtime state, OMX orchestration artifacts, design/research drafts and secrets.

# dependencies / package manager output
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# local environment and credentials
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# runtime state generated by the workbench UI/server
.workbench/run-history.jsonl
.workbench/tmp/
.workbench/sessions/
.workbench/uploads/
.workbench/**/*.log

# OMX / Codex orchestration state is internal development machinery
.omx/
.codex/

# development-only design and planning artifacts
DESIGN.md
design/
designs/
*.drawio
*.fig
*.sketch

# test / coverage / local build artifacts
coverage/
.nyc_output/
dist/
build/
.cache/
.tmp/
tmp/

# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
